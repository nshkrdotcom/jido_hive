cmd_live_demo() {
  require_base_tools

  local room_id="${ROOM_ID:-room-$(date +%s)}"
  local brief='Develop a distributed collaboration protocol for one or more AI workers.'
  local -a rules=('Every objection must target a claim.')
  local participant_count=''
  local -a target_ids=()
  local using_default_rules=1
  local max_assignments=''
  local assignment_timeout_ms="${JIDO_HIVE_ASSIGNMENT_TIMEOUT_MS:-180000}"
  local wait_timeout_ms='120000'
  local publish_from_env=0

  while (($# > 0)); do
    case "$1" in
      --room-id)
        shift
        [[ $# -gt 0 ]] || die "--room-id requires a value"
        room_id="$1"
        ;;

      --brief)
        shift
        [[ $# -gt 0 ]] || die "--brief requires a value"
        brief="$1"
        ;;

      --rule)
        shift
        [[ $# -gt 0 ]] || die "--rule requires a value"
        if (( using_default_rules )); then
          rules=()
          using_default_rules=0
        fi
        rules+=("$1")
        ;;

      --participant-count)
        shift
        [[ $# -gt 0 ]] || die "--participant-count requires a value"
        participant_count="$1"
        ;;

      --target)
        shift
        [[ $# -gt 0 ]] || die "--target requires a value"
        target_ids+=("$1")
        ;;

      --max-assignments)
        shift
        [[ $# -gt 0 ]] || die "--max-assignments requires a value"
        max_assignments="$1"
        ;;

      --assignment-timeout-ms)
        shift
        [[ $# -gt 0 ]] || die "--assignment-timeout-ms requires a value"
        assignment_timeout_ms="$1"
        ;;

      --wait-timeout-ms)
        shift
        [[ $# -gt 0 ]] || die "--wait-timeout-ms requires a value"
        wait_timeout_ms="$1"
        ;;

      --publish-from-env)
        publish_from_env=1
        ;;

      *)
        die "unknown option for live-demo: $1"
        ;;
    esac

    shift || true
  done

  local -a create_room_args=("$room_id" "--if-missing" "--brief" "$brief")
  local -a wait_target_args=(--timeout-ms "$wait_timeout_ms" --interval-ms 250)
  local -a run_room_args=("$room_id" --assignment-timeout-ms "$assignment_timeout_ms")
  local rule=''

  for rule in "${rules[@]}"; do
    create_room_args+=("--rule" "$rule")
  done

  if [[ -n "$participant_count" ]]; then
    create_room_args+=("--participant-count" "$participant_count")
    wait_target_args+=(--count "$participant_count")
  elif ((${#target_ids[@]} == 0)); then
    wait_target_args+=(--count 1)
  fi

  if [[ -n "$max_assignments" ]]; then
    run_room_args+=(--max-assignments "$max_assignments")
  fi

  for target_id in "${target_ids[@]}"; do
    create_room_args+=("--target" "$target_id")
    wait_target_args+=(--target "$target_id")
  done

  log "live demo room: $room_id"

  cmd_wait_server --timeout-ms "$wait_timeout_ms" --interval-ms 250 >/dev/null
  cmd_wait_targets "${wait_target_args[@]}" >/dev/null
  cmd_create_room "${create_room_args[@]}" >/dev/null

  printf '\n=== Starting Run %s ===\n' "$room_id"
  local run_operation_json
  run_operation_json="$(cmd_run_room "${run_room_args[@]}")"
  printf '%s\n' "$run_operation_json"

  local run_operation_id
  run_operation_id="$(jq -r '.data.operation_id // empty' <<<"$run_operation_json")"
  [[ -n "$run_operation_id" ]] || die "run-room did not return an operation id"

  printf '\n=== Waiting For Run Operation %s (%s) ===\n' "$room_id" "$run_operation_id"
  cmd_wait_run_operation "$room_id" "$run_operation_id" \
    --timeout-ms "$wait_timeout_ms" \
    --interval-ms 250

  printf '\n=== Room Snapshot %s ===\n' "$room_id"
  cmd_room "$room_id"
  printf '\n=== Publication Plan %s ===\n' "$room_id"
  cmd_publication_plan "$room_id"

  if (( publish_from_env == 0 )); then
    return 0
  fi

  local -a publish_args=("$room_id")
  local publish_enabled=0

  if [[ -n "${JIDO_HIVE_GITHUB_CONNECTION:-}" || -n "${JIDO_HIVE_GITHUB_REPO:-}" ]]; then
    [[ -n "${JIDO_HIVE_GITHUB_CONNECTION:-}" ]] || die "JIDO_HIVE_GITHUB_CONNECTION is required for GitHub publication"
    [[ -n "${JIDO_HIVE_GITHUB_REPO:-}" ]] || die "JIDO_HIVE_GITHUB_REPO is required for GitHub publication"
    publish_args+=(
      --github-connection "$JIDO_HIVE_GITHUB_CONNECTION"
      --github-repo "$JIDO_HIVE_GITHUB_REPO"
    )
    publish_enabled=1
  fi

  if [[ -n "${JIDO_HIVE_NOTION_CONNECTION:-}" || -n "${JIDO_HIVE_NOTION_DATA_SOURCE_ID:-}" ]]; then
    [[ -n "${JIDO_HIVE_NOTION_CONNECTION:-}" ]] || die "JIDO_HIVE_NOTION_CONNECTION is required for Notion publication"
    [[ -n "${JIDO_HIVE_NOTION_DATA_SOURCE_ID:-}" ]] || die "JIDO_HIVE_NOTION_DATA_SOURCE_ID is required for Notion publication"
    publish_args+=(
      --notion-connection "$JIDO_HIVE_NOTION_CONNECTION"
      --notion-data-source-id "$JIDO_HIVE_NOTION_DATA_SOURCE_ID"
      --notion-title-property "${JIDO_HIVE_NOTION_TITLE_PROPERTY:-Name}"
    )
    publish_enabled=1
  fi

  if (( publish_enabled == 0 )); then
    log "publish-from-env requested but no publish environment variables were set"
    return 0
  fi

  printf '\n=== Publication Run %s ===\n' "$room_id"
  cmd_publish "${publish_args[@]}"
  printf '\n=== Publication History %s ===\n' "$room_id"
  cmd_publication_runs "$room_id"
}

cmd_start_install() {
  require_base_tools

  local connector_id="${1:-}"
  [[ -n "$connector_id" ]] || die "connector id is required"
  shift || true

  local subject
  subject="$(default_subject_for_connector "$connector_id")"
  local auth_type='oauth2'
  local environment=''
  local -a scopes=()

  while (($# > 0)); do
    case "$1" in
      --subject)
        shift
        [[ $# -gt 0 ]] || die "--subject requires a value"
        subject="$1"
        ;;

      --scope)
        shift
        [[ $# -gt 0 ]] || die "--scope requires a value"
        scopes+=("$1")
        ;;

      --auth-type)
        shift
        [[ $# -gt 0 ]] || die "--auth-type requires a value"
        auth_type="$1"
        ;;

      --environment)
        shift
        [[ $# -gt 0 ]] || die "--environment requires a value"
        environment="$1"
        ;;

      *)
        die "unknown option for start-install: $1"
        ;;
    esac

    shift || true
  done

  local scopes_json='[]'
  if ((${#scopes[@]} > 0)); then
    scopes_json="$(printf '%s\n' "${scopes[@]}" | jq -R . | jq -s .)"
  fi

  local payload
  payload="$(
    jq -n \
      --arg tenant_id "$JIDO_HIVE_TENANT_ID" \
      --arg actor_id "$JIDO_HIVE_ACTOR_ID" \
      --arg auth_type "$auth_type" \
      --arg subject "$subject" \
      --arg environment "$environment" \
      --argjson requested_scopes "$scopes_json" \
      '{
        tenant_id: $tenant_id,
        actor_id: $actor_id,
        auth_type: $auth_type,
        subject: $subject
      }
      + (if ($requested_scopes | length) > 0 then {requested_scopes: $requested_scopes} else {} end)
      + (if $environment == "" then {} else {environment: $environment} end)'
  )"

  api_post "/connectors/$connector_id/installs" "$payload"
}

cmd_show_install() {
  require_base_tools

  local install_id="${1:-}"
  [[ -n "$install_id" ]] || die "install id is required"

  api_get "/connectors/installs/$install_id"
}

cmd_complete_install() {
  require_base_tools

  local install_id="${1:-}"
  [[ -n "$install_id" ]] || die "install id is required"
  shift || true

  local subject=''
  local access_token="${JIDO_HIVE_ACCESS_TOKEN:-}"
  local -a scopes=()

  while (($# > 0)); do
    case "$1" in
      --subject)
        shift
        [[ $# -gt 0 ]] || die "--subject requires a value"
        subject="$1"
        ;;

      --scope)
        shift
        [[ $# -gt 0 ]] || die "--scope requires a value"
        scopes+=("$1")
        ;;

      --access-token)
        shift
        [[ $# -gt 0 ]] || die "--access-token requires a value"
        access_token="$1"
        ;;

      *)
        die "unknown option for complete-install: $1"
        ;;
    esac

    shift || true
  done

  [[ -n "$subject" ]] || die "--subject is required for complete-install"
  [[ -n "$access_token" ]] || access_token="$(prompt_secret 'Access token: ')"

  local scopes_json='[]'
  if ((${#scopes[@]} > 0)); then
    scopes_json="$(printf '%s\n' "${scopes[@]}" | jq -R . | jq -s .)"
  fi

  local payload
  payload="$(
    jq -n \
      --arg subject "$subject" \
      --arg access_token "$access_token" \
      --argjson granted_scopes "$scopes_json" \
      '{
        subject: $subject,
        secret: {access_token: $access_token}
      }
      + (if ($granted_scopes | length) > 0 then {granted_scopes: $granted_scopes} else {} end)'
  )"

  api_post "/connectors/installs/$install_id/complete" "$payload"
}

cmd_connections() {
  require_base_tools

  local connector_id="${1:-}"
  [[ -n "$connector_id" ]] || die "connector id is required"
  shift || true

  local subject=''

  while (($# > 0)); do
    case "$1" in
      --subject)
        shift
        [[ $# -gt 0 ]] || die "--subject requires a value"
        subject="$1"
        ;;

      *)
        die "unknown option for connections: $1"
        ;;
    esac

    shift || true
  done

  local -a query_args=(
    --get
    --data-urlencode "tenant_id=$JIDO_HIVE_TENANT_ID"
  )

  if [[ -n "$subject" ]]; then
    query_args+=(--data-urlencode "subject=$subject")
  fi

  request_json \
    GET \
    "${JIDO_HIVE_API_BASE}/connectors/$connector_id/connections" \
    "" \
    "${query_args[@]}"
}

cmd_publish() {
  require_base_tools

  local room_id="${1:-}"
  require_room_id "$room_id"
  shift || true

  local github_connection=''
  local github_repo=''
  local notion_connection=''
  local notion_data_source_id=''
  local notion_title_property='Name'

  while (($# > 0)); do
    case "$1" in
      --github-connection)
        shift
        [[ $# -gt 0 ]] || die "--github-connection requires a value"
        github_connection="$1"
        ;;

      --github-repo)
        shift
        [[ $# -gt 0 ]] || die "--github-repo requires a value"
        github_repo="$1"
        ;;

      --notion-connection)
        shift
        [[ $# -gt 0 ]] || die "--notion-connection requires a value"
        notion_connection="$1"
        ;;

      --notion-data-source-id)
        shift
        [[ $# -gt 0 ]] || die "--notion-data-source-id requires a value"
        notion_data_source_id="$1"
        ;;

      --notion-title-property)
        shift
        [[ $# -gt 0 ]] || die "--notion-title-property requires a value"
        notion_title_property="$1"
        ;;

      *)
        die "unknown option for publish: $1"
        ;;
    esac

    shift || true
  done

  local -a channels=()

  if [[ -n "$github_connection" || -n "$github_repo" ]]; then
    [[ -n "$github_connection" ]] || die "publish requires --github-connection when GitHub is selected"
    [[ -n "$github_repo" ]] || die "publish requires --github-repo when GitHub is selected"
    channels+=("github")
  fi

  if [[ -n "$notion_connection" || -n "$notion_data_source_id" ]]; then
    [[ -n "$notion_connection" ]] || die "publish requires --notion-connection when Notion is selected"
    [[ -n "$notion_data_source_id" ]] || die "publish requires --notion-data-source-id when Notion is selected"
    channels+=("notion")
  fi

  ((${#channels[@]} > 0)) || die "publish requires at least one channel"

  local channels_json
  channels_json="$(printf '%s\n' "${channels[@]}" | jq -R . | jq -s .)"

  local payload
  payload="$(
    jq -n \
      --arg tenant_id "$JIDO_HIVE_TENANT_ID" \
      --arg actor_id "$JIDO_HIVE_ACTOR_ID" \
      --arg github_connection "$github_connection" \
      --arg github_repo "$github_repo" \
      --arg notion_connection "$notion_connection" \
      --arg notion_data_source_id "$notion_data_source_id" \
      --arg notion_title_property "$notion_title_property" \
      --argjson channels "$channels_json" \
      '{
        channels: $channels,
        actor_id: $actor_id,
        tenant_id: $tenant_id,
        connections: {},
        bindings: {}
      }
      | if $github_connection == "" then . else
          .connections.github = $github_connection
          | .bindings.github = {repo: $github_repo}
        end
      | if $notion_connection == "" then . else
          .connections.notion = $notion_connection
          | .bindings.notion = {
              "parent.data_source_id": $notion_data_source_id,
              title_property: $notion_title_property
            }
        end'
  )"

  api_post "/rooms/$room_id/publications" "$payload"
}

