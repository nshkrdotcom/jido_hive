}

cmd_room() {
  require_base_tools

  local room_id="${1:-}"
  require_room_id "$room_id"

  api_get "/rooms/$room_id"
}

cmd_create_room() {
  require_base_tools

  local room_id="${1:-room-$(date +%s)}"
  local if_missing=0

  if [[ "${room_id#--}" != "$room_id" ]]; then
    room_id="room-$(date +%s)"
  else
    shift || true
  fi

  local brief='Develop a distributed collaboration protocol for one or more AI workers.'
  local participant_count=''
  local -a rules=('Every objection must target a claim.')
  local -a target_ids=()
  local using_default_rules=1

  while (($# > 0)); do
    case "$1" in
      --brief)
        shift
        [[ $# -gt 0 ]] || die "--brief requires a value"
        brief="$1"
        ;;

      --rule)
        shift
        [[ $# -gt 0 ]] || die "--rule requires a value"
        if (( using_default_rules )); then
          rules=()
          using_default_rules=0
        fi
        rules+=("$1")
        ;;

      --participant-count)
        shift
        [[ $# -gt 0 ]] || die "--participant-count requires a value"
        participant_count="$1"
        ;;

      --target)
        shift
        [[ $# -gt 0 ]] || die "--target requires a value"
        target_ids+=("$1")
        ;;

      --if-missing)
        if_missing=1
        ;;

      *)
        die "unknown option for create-room: $1"
        ;;
    esac

    shift || true
  done

  local selected_targets_json
  selected_targets_json="$(select_room_targets "$participant_count" "${target_ids[@]}")"

  log "locking room $room_id to targets: $(describe_selected_targets <<<"$selected_targets_json")"

  local payload
  payload="$(build_room_payload "$room_id" "$brief" "$selected_targets_json" "${rules[@]}")"

  log "creating room: $room_id"

  if (( if_missing == 0 )); then
    api_post "/rooms" "$payload"
    return 0
  fi

  perform_request POST "${JIDO_HIVE_API_BASE}/rooms" "$payload"

  case "$JIDO_HIVE_HTTP_STATUS" in
    201)
      json_print_file "$JIDO_HIVE_HTTP_BODY_FILE"
      cleanup_http_response
      ;;

    409)
      cleanup_http_response
      log "room already exists, reusing: $room_id"
      api_get "/rooms/$room_id"
      ;;

    *)
      log "POST ${JIDO_HIVE_API_BASE}/rooms failed with HTTP $JIDO_HIVE_HTTP_STATUS"
      json_print_file "$JIDO_HIVE_HTTP_BODY_FILE" >&2 || cat "$JIDO_HIVE_HTTP_BODY_FILE" >&2
      cleanup_http_response
      exit 1
      ;;
  esac
}

cmd_run_room() {
  require_base_tools

  local room_id="${1:-}"
  require_room_id "$room_id"
  shift || true

  local max_assignments=''
  local assignment_timeout_ms='180000'

  while (($# > 0)); do
    case "$1" in
      --max-assignments)
        shift
        [[ $# -gt 0 ]] || die "--max-assignments requires a value"
        max_assignments="$1"
        ;;

      --assignment-timeout-ms)
        shift
        [[ $# -gt 0 ]] || die "--assignment-timeout-ms requires a value"
        assignment_timeout_ms="$1"
        ;;

      *)
        die "unknown option for run-room: $1"
        ;;
    esac

    shift || true
  done

  local payload
  if [[ -n "$max_assignments" ]]; then
    payload="$(
      jq -n \
        --argjson max_assignments "$max_assignments" \
        --argjson assignment_timeout_ms "$assignment_timeout_ms" \
        '{
          max_assignments: $max_assignments,
          assignment_timeout_ms: $assignment_timeout_ms
        }'
    )"
  else
    payload="$(
      jq -n \
        --argjson assignment_timeout_ms "$assignment_timeout_ms" \
        '{
          assignment_timeout_ms: $assignment_timeout_ms
        }'
    )"
  fi

  api_post "/rooms/$room_id/run_operations" "$payload"
}

cmd_show_run_operation() {
  require_base_tools

  local room_id="${1:-}"
  local operation_id="${2:-}"

  require_room_id "$room_id"
  [[ -n "$operation_id" ]] || die "operation id is required"

  api_get "/rooms/$room_id/run_operations/$operation_id"
}

cmd_wait_run_operation() {
  require_base_tools

  local room_id="${1:-}"
  local operation_id="${2:-}"

  require_room_id "$room_id"
  [[ -n "$operation_id" ]] || die "operation id is required"
  shift 2 || true

  local timeout_ms='120000'
  local interval_ms='250'

  while (($# > 0)); do
    case "$1" in
      --timeout-ms)
        shift
        [[ $# -gt 0 ]] || die "--timeout-ms requires a value"
        timeout_ms="$1"
        ;;

      --interval-ms)
        shift
        [[ $# -gt 0 ]] || die "--interval-ms requires a value"
        interval_ms="$1"
        ;;

      *)
        die "unknown option for wait-run-operation: $1"
        ;;
    esac

    shift || true
  done

  local deadline_ms
  deadline_ms=$(( $(date +%s%3N) + timeout_ms ))

  while true; do
    perform_request GET "${JIDO_HIVE_API_BASE}/rooms/${room_id}/run_operations/${operation_id}" ""

    case "$JIDO_HIVE_HTTP_STATUS" in
      200)
        local status=''
        status="$(jq -r '.data.status // empty' "$JIDO_HIVE_HTTP_BODY_FILE")"

        case "$status" in
          accepted|running)
            cleanup_http_response
            ;;

          completed)
            json_print_file "$JIDO_HIVE_HTTP_BODY_FILE"
            cleanup_http_response
            return 0
            ;;

          failed)
            json_print_file "$JIDO_HIVE_HTTP_BODY_FILE" >&2
            cleanup_http_response
            return 1
            ;;

          *)
            json_print_file "$JIDO_HIVE_HTTP_BODY_FILE" >&2
            cleanup_http_response
            die "unexpected run operation status: ${status:-missing}"
            ;;
        esac
        ;;

      404)
        cleanup_http_response
        ;;

      *)
        log "GET ${JIDO_HIVE_API_BASE}/rooms/${room_id}/run_operations/${operation_id} failed with HTTP $JIDO_HIVE_HTTP_STATUS"
        json_print_file "$JIDO_HIVE_HTTP_BODY_FILE" >&2 || cat "$JIDO_HIVE_HTTP_BODY_FILE" >&2
        cleanup_http_response
        return 1
        ;;
    esac

    if (( $(date +%s%3N) >= deadline_ms )); then
      die "timed out waiting for run operation ${operation_id} in room ${room_id}"
    fi

    sleep "$(awk "BEGIN { printf \"%.3f\", ${interval_ms}/1000 }")"
  done
}

