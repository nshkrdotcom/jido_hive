    --github-repo owner/repo
EOF
}

require_room_id() {
  local room_id="${1:-}"
  [[ -n "$room_id" ]] || die "room id is required"
}

build_room_payload() {
  local room_id="$1"
  local brief="$2"
  local targets_json="$3"
  shift 3 || true

  local -a rules=("$@")
  local rules_json

  rules_json="$(printf '%s\n' "${rules[@]}" | jq -R . | jq -s .)"

  jq -n \
    --arg room_id "$room_id" \
    --arg brief "$brief" \
    --argjson targets "$targets_json" \
    --argjson rules "$rules_json" \
    '{
      room_id: $room_id,
      brief: $brief,
      rules: $rules,
      participants:
        ($targets | map({
          participant_id: .participant_id,
          participant_role: (.participant_role // "worker"),
          target_id: .target_id,
          capability_id: .capability_id
        }))
    }'
}

select_room_targets() {
  local participant_count="${1:-}"
  shift || true

  local -a target_ids=("$@")
  local targets_json='' selected_json='' target_ids_json='[]'
  local selected_count='' requested_target_count=''

  targets_json="$(fetch_targets_json)" ||
    die "cannot reach $JIDO_HIVE_API_BASE; start the server with bin/server or set JIDO_HIVE_API_BASE"

  if ((${#target_ids[@]} > 0)); then
    target_ids_json="$(printf '%s\n' "${target_ids[@]}" | jq -R . | jq -s .)"
  fi

  selected_json="$(
    jq \
      --arg capability_id "$JIDO_HIVE_EXEC_CAPABILITY_ID" \
      --argjson target_ids "$target_ids_json" \
      '
      .data
      | map(select(.capability_id == $capability_id))
      | sort_by(.participant_id, .target_id)
      | if ($target_ids | length) == 0
          then .
          else map(select(.target_id as $target_id | $target_ids | index($target_id)))
        end
      ' <<<"$targets_json"
  )"

  if [[ -n "$participant_count" ]]; then
    selected_json="$(jq --argjson participant_count "$participant_count" '.[0:$participant_count]' <<<"$selected_json")"
  fi

  selected_count="$(jq 'length' <<<"$selected_json")"
  requested_target_count="${#target_ids[@]}"

  if (( requested_target_count > 0 && selected_count < requested_target_count )); then
    die "not all requested targets are connected for capability $JIDO_HIVE_EXEC_CAPABILITY_ID"
  fi

  if [[ -n "$participant_count" && "$selected_count" -lt "$participant_count" ]]; then
    die "requested $participant_count participants but only $selected_count compatible targets are connected"
  fi

  if (( selected_count == 0 )); then
    die "no compatible relay targets are connected for capability $JIDO_HIVE_EXEC_CAPABILITY_ID"
  fi

  printf '%s\n' "$selected_json"
}

describe_selected_targets() {
  jq -r 'map("\(.participant_id)@\(.target_id)") | join(", ")'
}

cmd_wait_server() {
  require_base_tools

  local timeout_ms='30000'
  local interval_ms='250'

  while (($# > 0)); do
    case "$1" in
      --timeout-ms)
        shift
        [[ $# -gt 0 ]] || die "--timeout-ms requires a value"
        timeout_ms="$1"
        ;;

      --interval-ms)
        shift
        [[ $# -gt 0 ]] || die "--interval-ms requires a value"
        interval_ms="$1"
        ;;

      *)
        die "unknown option for wait-server: $1"
        ;;
    esac

    shift || true
  done

  log "waiting for API on $JIDO_HIVE_API_BASE"
  wait_for_api "$timeout_ms" "$interval_ms"
  log "API is reachable"
}

cmd_wait_targets() {
  require_base_tools

  local timeout_ms='30000'
  local interval_ms='250'
  local target_count='1'
  local -a targets=()

  while (($# > 0)); do
    case "$1" in
      --timeout-ms)
        shift
        [[ $# -gt 0 ]] || die "--timeout-ms requires a value"
        timeout_ms="$1"
        ;;

      --interval-ms)
        shift
        [[ $# -gt 0 ]] || die "--interval-ms requires a value"
        interval_ms="$1"
        ;;

      --target)
        shift
        [[ $# -gt 0 ]] || die "--target requires a value"
        targets+=("$1")
        ;;

      --count)
        shift
        [[ $# -gt 0 ]] || die "--count requires a value"
        target_count="$1"
        ;;

      *)
        die "unknown option for wait-targets: $1"
        ;;
    esac

    shift || true
  done

  if ((${#targets[@]} > 0)); then
    log "waiting for targets: ${targets[*]}"
    wait_for_targets "$timeout_ms" "$interval_ms" "${targets[@]}"
  else
    log "waiting for at least $target_count targets"
    wait_for_target_count "$timeout_ms" "$interval_ms" "$target_count"
  fi
}

cmd_doctor() {
  require_base_tools

  log "API base: $JIDO_HIVE_API_BASE"
  log "root base: $(root_base_url)"
  log "tenant id: $JIDO_HIVE_TENANT_ID"
  log "actor id: $JIDO_HIVE_ACTOR_ID"

  cmd_wait_server --timeout-ms 3000 --interval-ms 250 >/dev/null
  verify_server_contract
  cmd_targets
}

cmd_server_info() {
  require_base_tools

  local server_info_json=''
  server_info_json="$(fetch_server_info_json)" ||
    die "cannot reach $(root_base_url); start the server with bin/server or set JIDO_HIVE_API_BASE"

  jq . <<<"$server_info_json"
}

verify_server_contract() {
  local server_info_json=''
  server_info_json="$(fetch_server_info_json)" ||
    die "cannot reach $(root_base_url); start the server with bin/server or set JIDO_HIVE_API_BASE"

  local summary=''
  summary="$(
    jq -r '
      if .demo.strategy != "round_robin" then
        "expected demo.strategy=round_robin but got \(.demo.strategy // "null")"
      elif .demo.max_clients != 39 then
        "expected demo.max_clients=39 but got \(.demo.max_clients // "null")"
      elif .demo.planned_turn_formula != "participant_count * 3" then
        "expected demo.planned_turn_formula=participant_count * 3 but got \(.demo.planned_turn_formula // "null")"
      else
        "ok strategy=\(.demo.strategy) max_clients=\(.demo.max_clients) planned_turn_formula=\(.demo.planned_turn_formula)"
      end
    ' <<<"$server_info_json"
  )"

  case "$summary" in
    ok\ *)
      log "server contract verified: ${summary#ok }"
      ;;

    *)
      die "server contract check failed: $summary"
      ;;
  esac
}

