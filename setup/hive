#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
LOCAL_API_BASE="http://127.0.0.1:4000/api"
PROD_API_BASE="https://jido-hive-server-test.app.nsai.online/api"

mode="local"

case "${1:-}" in
  --local)
    mode="local"
    shift
    ;;
  --prod)
    mode="prod"
    shift
    ;;
esac

if [[ -z "${JIDO_HIVE_API_BASE:-}" ]]; then
  case "$mode" in
    local) export JIDO_HIVE_API_BASE="$LOCAL_API_BASE" ;;
    prod) export JIDO_HIVE_API_BASE="$PROD_API_BASE" ;;
  esac
fi

# shellcheck source=setup/lib.sh
source "$ROOT/setup/lib.sh"

usage() {
  cat <<'EOF'
Usage:
  setup/hive [--local|--prod] help
  setup/hive [--local|--prod] doctor
  setup/hive [--local|--prod] wait-server
  setup/hive [--local|--prod] wait-targets
  setup/hive [--local|--prod] targets
  setup/hive [--local|--prod] room ROOM_ID
  setup/hive [--local|--prod] create-room [ROOM_ID] [--brief TEXT] [--rule TEXT] [--if-missing]
  setup/hive [--local|--prod] run-room ROOM_ID [--max-turns N] [--turn-timeout-ms N]
  setup/hive [--local|--prod] publication-plan ROOM_ID
  setup/hive [--local|--prod] publication-runs ROOM_ID
  setup/hive [--local|--prod] live-demo [--room-id ROOM_ID] [--brief TEXT] [--rule TEXT]
      [--max-turns N] [--turn-timeout-ms N] [--wait-timeout-ms N]
      [--publish-from-env]
  setup/hive [--local|--prod] start-install github|notion [--subject VALUE] [--scope VALUE]
  setup/hive [--local|--prod] show-install INSTALL_ID
  setup/hive [--local|--prod] complete-install INSTALL_ID [--subject VALUE]
      [--scope VALUE] [--access-token VALUE]
  setup/hive [--local|--prod] connections github|notion [--subject VALUE]
  setup/hive [--local|--prod] publish ROOM_ID
      [--github-connection ID --github-repo OWNER/REPO]
      [--notion-connection ID --notion-data-source-id ID]
      [--notion-title-property NAME]

Environment defaults:
  JIDO_HIVE_API_BASE    default local: http://127.0.0.1:4000/api
                        default prod:  https://jido-hive-server-test.app.nsai.online/api
  JIDO_HIVE_TENANT_ID   default: workspace-local
  JIDO_HIVE_ACTOR_ID    default: operator-1
  JIDO_HIVE_GITHUB_SUBJECT
  JIDO_HIVE_NOTION_SUBJECT

Examples:
  setup/hive doctor
  setup/hive --prod doctor
  setup/hive wait-targets
  setup/hive create-room room-manual-1
  setup/hive run-room room-manual-1 --turn-timeout-ms 180000
  setup/hive live-demo --room-id room-live-demo
  setup/hive publication-plan room-manual-1
  setup/hive start-install github --subject octocat --scope repo
  setup/hive complete-install install-123 --subject octocat
  setup/hive connections github
  setup/hive publish room-manual-1 \
    --github-connection connection-github-1 \
    --github-repo owner/repo
EOF
}

require_room_id() {
  local room_id="${1:-}"
  [[ -n "$room_id" ]] || die "room id is required"
}

build_room_payload() {
  local room_id="$1"
  local brief="$2"
  shift 2 || true

  local -a rules=("$@")
  local rules_json

  rules_json="$(printf '%s\n' "${rules[@]}" | jq -R . | jq -s .)"

  jq -n \
    --arg room_id "$room_id" \
    --arg brief "$brief" \
    --argjson rules "$rules_json" \
    '{
      room_id: $room_id,
      brief: $brief,
      rules: $rules,
      participants: [
        {
          participant_id: "architect",
          role: "architect",
          target_id: "target-architect",
          capability_id: "codex.exec.session"
        },
        {
          participant_id: "skeptic",
          role: "skeptic",
          target_id: "target-skeptic",
          capability_id: "codex.exec.session"
        }
      ]
    }'
}

cmd_wait_server() {
  require_base_tools

  local timeout_ms='30000'
  local interval_ms='250'

  while (($# > 0)); do
    case "$1" in
      --timeout-ms)
        shift
        [[ $# -gt 0 ]] || die "--timeout-ms requires a value"
        timeout_ms="$1"
        ;;

      --interval-ms)
        shift
        [[ $# -gt 0 ]] || die "--interval-ms requires a value"
        interval_ms="$1"
        ;;

      *)
        die "unknown option for wait-server: $1"
        ;;
    esac

    shift || true
  done

  log "waiting for API on $JIDO_HIVE_API_BASE"
  wait_for_api "$timeout_ms" "$interval_ms"
  log "API is reachable"
}

cmd_wait_targets() {
  require_base_tools

  local timeout_ms='30000'
  local interval_ms='250'
  local -a targets=('target-architect' 'target-skeptic')
  local using_default_targets=1

  while (($# > 0)); do
    case "$1" in
      --timeout-ms)
        shift
        [[ $# -gt 0 ]] || die "--timeout-ms requires a value"
        timeout_ms="$1"
        ;;

      --interval-ms)
        shift
        [[ $# -gt 0 ]] || die "--interval-ms requires a value"
        interval_ms="$1"
        ;;

      --target)
        shift
        [[ $# -gt 0 ]] || die "--target requires a value"
        if (( using_default_targets )); then
          targets=()
          using_default_targets=0
        fi
        targets+=("$1")
        ;;

      *)
        die "unknown option for wait-targets: $1"
        ;;
    esac

    shift || true
  done

  log "waiting for targets: ${targets[*]}"
  wait_for_targets "$timeout_ms" "$interval_ms" "${targets[@]}"
}

cmd_doctor() {
  require_base_tools

  log "API base: $JIDO_HIVE_API_BASE"
  log "tenant id: $JIDO_HIVE_TENANT_ID"
  log "actor id: $JIDO_HIVE_ACTOR_ID"

  cmd_wait_server --timeout-ms 3000 --interval-ms 250 >/dev/null
  cmd_targets
}

cmd_targets() {
  require_base_tools
  api_get "/targets"
}

cmd_room() {
  require_base_tools

  local room_id="${1:-}"
  require_room_id "$room_id"

  api_get "/rooms/$room_id"
}

cmd_create_room() {
  require_base_tools

  local room_id="${1:-room-$(date +%s)}"
  local if_missing=0

  if [[ "${room_id#--}" != "$room_id" ]]; then
    room_id="room-$(date +%s)"
  else
    shift || true
  fi

  local brief='Develop a distributed collaboration protocol for two AI clients.'
  local -a rules=('Every objection must target a claim.')
  local using_default_rules=1

  while (($# > 0)); do
    case "$1" in
      --brief)
        shift
        [[ $# -gt 0 ]] || die "--brief requires a value"
        brief="$1"
        ;;

      --rule)
        shift
        [[ $# -gt 0 ]] || die "--rule requires a value"
        if (( using_default_rules )); then
          rules=()
          using_default_rules=0
        fi
        rules+=("$1")
        ;;

      --if-missing)
        if_missing=1
        ;;

      *)
        die "unknown option for create-room: $1"
        ;;
    esac

    shift || true
  done

  local payload
  payload="$(build_room_payload "$room_id" "$brief" "${rules[@]}")"

  log "creating room: $room_id"

  if (( if_missing == 0 )); then
    api_post "/rooms" "$payload"
    return 0
  fi

  perform_request POST "${JIDO_HIVE_API_BASE}/rooms" "$payload"

  case "$JIDO_HIVE_HTTP_STATUS" in
    201)
      json_print_file "$JIDO_HIVE_HTTP_BODY_FILE"
      cleanup_http_response
      ;;

    409)
      cleanup_http_response
      log "room already exists, reusing: $room_id"
      api_get "/rooms/$room_id"
      ;;

    *)
      log "POST ${JIDO_HIVE_API_BASE}/rooms failed with HTTP $JIDO_HIVE_HTTP_STATUS"
      json_print_file "$JIDO_HIVE_HTTP_BODY_FILE" >&2 || cat "$JIDO_HIVE_HTTP_BODY_FILE" >&2
      cleanup_http_response
      exit 1
      ;;
  esac
}

cmd_run_room() {
  require_base_tools

  local room_id="${1:-}"
  require_room_id "$room_id"
  shift || true

  local max_turns='6'
  local turn_timeout_ms='180000'

  while (($# > 0)); do
    case "$1" in
      --max-turns)
        shift
        [[ $# -gt 0 ]] || die "--max-turns requires a value"
        max_turns="$1"
        ;;

      --turn-timeout-ms)
        shift
        [[ $# -gt 0 ]] || die "--turn-timeout-ms requires a value"
        turn_timeout_ms="$1"
        ;;

      *)
        die "unknown option for run-room: $1"
        ;;
    esac

    shift || true
  done

  local payload
  payload="$(
    jq -n \
      --argjson max_turns "$max_turns" \
      --argjson turn_timeout_ms "$turn_timeout_ms" \
      '{
        max_turns: $max_turns,
        turn_timeout_ms: $turn_timeout_ms
      }'
  )"

  api_post "/rooms/$room_id/run" "$payload"
}

cmd_publication_plan() {
  require_base_tools

  local room_id="${1:-}"
  require_room_id "$room_id"

  api_get "/rooms/$room_id/publication_plan"
}

cmd_publication_runs() {
  require_base_tools

  local room_id="${1:-}"
  require_room_id "$room_id"

  api_get "/rooms/$room_id/publications"
}

cmd_live_demo() {
  require_base_tools

  local room_id="${ROOM_ID:-room-$(date +%s)}"
  local brief='Develop a distributed collaboration protocol for two AI clients.'
  local -a rules=('Every objection must target a claim.')
  local using_default_rules=1
  local max_turns='6'
  local turn_timeout_ms="${JIDO_HIVE_TURN_TIMEOUT_MS:-180000}"
  local wait_timeout_ms='120000'
  local publish_from_env=0

  while (($# > 0)); do
    case "$1" in
      --room-id)
        shift
        [[ $# -gt 0 ]] || die "--room-id requires a value"
        room_id="$1"
        ;;

      --brief)
        shift
        [[ $# -gt 0 ]] || die "--brief requires a value"
        brief="$1"
        ;;

      --rule)
        shift
        [[ $# -gt 0 ]] || die "--rule requires a value"
        if (( using_default_rules )); then
          rules=()
          using_default_rules=0
        fi
        rules+=("$1")
        ;;

      --max-turns)
        shift
        [[ $# -gt 0 ]] || die "--max-turns requires a value"
        max_turns="$1"
        ;;

      --turn-timeout-ms)
        shift
        [[ $# -gt 0 ]] || die "--turn-timeout-ms requires a value"
        turn_timeout_ms="$1"
        ;;

      --wait-timeout-ms)
        shift
        [[ $# -gt 0 ]] || die "--wait-timeout-ms requires a value"
        wait_timeout_ms="$1"
        ;;

      --publish-from-env)
        publish_from_env=1
        ;;

      *)
        die "unknown option for live-demo: $1"
        ;;
    esac

    shift || true
  done

  local -a create_room_args=("$room_id" "--if-missing" "--brief" "$brief")
  local rule=''

  for rule in "${rules[@]}"; do
    create_room_args+=("--rule" "$rule")
  done

  log "live demo room: $room_id"

  cmd_wait_server --timeout-ms "$wait_timeout_ms" --interval-ms 250 >/dev/null
  cmd_wait_targets --timeout-ms "$wait_timeout_ms" --interval-ms 250 >/dev/null
  cmd_create_room "${create_room_args[@]}" >/dev/null

  printf '\n=== Running Room %s ===\n' "$room_id"
  cmd_run_room "$room_id" --max-turns "$max_turns" --turn-timeout-ms "$turn_timeout_ms"
  printf '\n=== Room Snapshot %s ===\n' "$room_id"
  cmd_room "$room_id"
  printf '\n=== Publication Plan %s ===\n' "$room_id"
  cmd_publication_plan "$room_id"

  if (( publish_from_env == 0 )); then
    return 0
  fi

  local -a publish_args=("$room_id")
  local publish_enabled=0

  if [[ -n "${JIDO_HIVE_GITHUB_CONNECTION:-}" || -n "${JIDO_HIVE_GITHUB_REPO:-}" ]]; then
    [[ -n "${JIDO_HIVE_GITHUB_CONNECTION:-}" ]] || die "JIDO_HIVE_GITHUB_CONNECTION is required for GitHub publication"
    [[ -n "${JIDO_HIVE_GITHUB_REPO:-}" ]] || die "JIDO_HIVE_GITHUB_REPO is required for GitHub publication"
    publish_args+=(
      --github-connection "$JIDO_HIVE_GITHUB_CONNECTION"
      --github-repo "$JIDO_HIVE_GITHUB_REPO"
    )
    publish_enabled=1
  fi

  if [[ -n "${JIDO_HIVE_NOTION_CONNECTION:-}" || -n "${JIDO_HIVE_NOTION_DATA_SOURCE_ID:-}" ]]; then
    [[ -n "${JIDO_HIVE_NOTION_CONNECTION:-}" ]] || die "JIDO_HIVE_NOTION_CONNECTION is required for Notion publication"
    [[ -n "${JIDO_HIVE_NOTION_DATA_SOURCE_ID:-}" ]] || die "JIDO_HIVE_NOTION_DATA_SOURCE_ID is required for Notion publication"
    publish_args+=(
      --notion-connection "$JIDO_HIVE_NOTION_CONNECTION"
      --notion-data-source-id "$JIDO_HIVE_NOTION_DATA_SOURCE_ID"
      --notion-title-property "${JIDO_HIVE_NOTION_TITLE_PROPERTY:-Name}"
    )
    publish_enabled=1
  fi

  if (( publish_enabled == 0 )); then
    log "publish-from-env requested but no publish environment variables were set"
    return 0
  fi

  printf '\n=== Publication Run %s ===\n' "$room_id"
  cmd_publish "${publish_args[@]}"
  printf '\n=== Publication History %s ===\n' "$room_id"
  cmd_publication_runs "$room_id"
}

cmd_start_install() {
  require_base_tools

  local connector_id="${1:-}"
  [[ -n "$connector_id" ]] || die "connector id is required"
  shift || true

  local subject
  subject="$(default_subject_for_connector "$connector_id")"
  local auth_type='oauth2'
  local environment=''
  local -a scopes=()

  while (($# > 0)); do
    case "$1" in
      --subject)
        shift
        [[ $# -gt 0 ]] || die "--subject requires a value"
        subject="$1"
        ;;

      --scope)
        shift
        [[ $# -gt 0 ]] || die "--scope requires a value"
        scopes+=("$1")
        ;;

      --auth-type)
        shift
        [[ $# -gt 0 ]] || die "--auth-type requires a value"
        auth_type="$1"
        ;;

      --environment)
        shift
        [[ $# -gt 0 ]] || die "--environment requires a value"
        environment="$1"
        ;;

      *)
        die "unknown option for start-install: $1"
        ;;
    esac

    shift || true
  done

  local scopes_json='[]'
  if ((${#scopes[@]} > 0)); then
    scopes_json="$(printf '%s\n' "${scopes[@]}" | jq -R . | jq -s .)"
  fi

  local payload
  payload="$(
    jq -n \
      --arg tenant_id "$JIDO_HIVE_TENANT_ID" \
      --arg actor_id "$JIDO_HIVE_ACTOR_ID" \
      --arg auth_type "$auth_type" \
      --arg subject "$subject" \
      --arg environment "$environment" \
      --argjson requested_scopes "$scopes_json" \
      '{
        tenant_id: $tenant_id,
        actor_id: $actor_id,
        auth_type: $auth_type,
        subject: $subject
      }
      + (if ($requested_scopes | length) > 0 then {requested_scopes: $requested_scopes} else {} end)
      + (if $environment == "" then {} else {environment: $environment} end)'
  )"

  api_post "/connectors/$connector_id/installs" "$payload"
}

cmd_show_install() {
  require_base_tools

  local install_id="${1:-}"
  [[ -n "$install_id" ]] || die "install id is required"

  api_get "/connectors/installs/$install_id"
}

cmd_complete_install() {
  require_base_tools

  local install_id="${1:-}"
  [[ -n "$install_id" ]] || die "install id is required"
  shift || true

  local subject=''
  local access_token="${JIDO_HIVE_ACCESS_TOKEN:-}"
  local -a scopes=()

  while (($# > 0)); do
    case "$1" in
      --subject)
        shift
        [[ $# -gt 0 ]] || die "--subject requires a value"
        subject="$1"
        ;;

      --scope)
        shift
        [[ $# -gt 0 ]] || die "--scope requires a value"
        scopes+=("$1")
        ;;

      --access-token)
        shift
        [[ $# -gt 0 ]] || die "--access-token requires a value"
        access_token="$1"
        ;;

      *)
        die "unknown option for complete-install: $1"
        ;;
    esac

    shift || true
  done

  [[ -n "$subject" ]] || die "--subject is required for complete-install"
  [[ -n "$access_token" ]] || access_token="$(prompt_secret 'Access token: ')"

  local scopes_json='[]'
  if ((${#scopes[@]} > 0)); then
    scopes_json="$(printf '%s\n' "${scopes[@]}" | jq -R . | jq -s .)"
  fi

  local payload
  payload="$(
    jq -n \
      --arg subject "$subject" \
      --arg access_token "$access_token" \
      --argjson granted_scopes "$scopes_json" \
      '{
        subject: $subject,
        secret: {access_token: $access_token}
      }
      + (if ($granted_scopes | length) > 0 then {granted_scopes: $granted_scopes} else {} end)'
  )"

  api_post "/connectors/installs/$install_id/complete" "$payload"
}

cmd_connections() {
  require_base_tools

  local connector_id="${1:-}"
  [[ -n "$connector_id" ]] || die "connector id is required"
  shift || true

  local subject=''

  while (($# > 0)); do
    case "$1" in
      --subject)
        shift
        [[ $# -gt 0 ]] || die "--subject requires a value"
        subject="$1"
        ;;

      *)
        die "unknown option for connections: $1"
        ;;
    esac

    shift || true
  done

  local -a query_args=(
    --get
    --data-urlencode "tenant_id=$JIDO_HIVE_TENANT_ID"
  )

  if [[ -n "$subject" ]]; then
    query_args+=(--data-urlencode "subject=$subject")
  fi

  request_json \
    GET \
    "${JIDO_HIVE_API_BASE}/connectors/$connector_id/connections" \
    "" \
    "${query_args[@]}"
}

cmd_publish() {
  require_base_tools

  local room_id="${1:-}"
  require_room_id "$room_id"
  shift || true

  local github_connection=''
  local github_repo=''
  local notion_connection=''
  local notion_data_source_id=''
  local notion_title_property='Name'

  while (($# > 0)); do
    case "$1" in
      --github-connection)
        shift
        [[ $# -gt 0 ]] || die "--github-connection requires a value"
        github_connection="$1"
        ;;

      --github-repo)
        shift
        [[ $# -gt 0 ]] || die "--github-repo requires a value"
        github_repo="$1"
        ;;

      --notion-connection)
        shift
        [[ $# -gt 0 ]] || die "--notion-connection requires a value"
        notion_connection="$1"
        ;;

      --notion-data-source-id)
        shift
        [[ $# -gt 0 ]] || die "--notion-data-source-id requires a value"
        notion_data_source_id="$1"
        ;;

      --notion-title-property)
        shift
        [[ $# -gt 0 ]] || die "--notion-title-property requires a value"
        notion_title_property="$1"
        ;;

      *)
        die "unknown option for publish: $1"
        ;;
    esac

    shift || true
  done

  local -a channels=()

  if [[ -n "$github_connection" || -n "$github_repo" ]]; then
    [[ -n "$github_connection" ]] || die "publish requires --github-connection when GitHub is selected"
    [[ -n "$github_repo" ]] || die "publish requires --github-repo when GitHub is selected"
    channels+=("github")
  fi

  if [[ -n "$notion_connection" || -n "$notion_data_source_id" ]]; then
    [[ -n "$notion_connection" ]] || die "publish requires --notion-connection when Notion is selected"
    [[ -n "$notion_data_source_id" ]] || die "publish requires --notion-data-source-id when Notion is selected"
    channels+=("notion")
  fi

  ((${#channels[@]} > 0)) || die "publish requires at least one channel"

  local channels_json
  channels_json="$(printf '%s\n' "${channels[@]}" | jq -R . | jq -s .)"

  local payload
  payload="$(
    jq -n \
      --arg tenant_id "$JIDO_HIVE_TENANT_ID" \
      --arg actor_id "$JIDO_HIVE_ACTOR_ID" \
      --arg github_connection "$github_connection" \
      --arg github_repo "$github_repo" \
      --arg notion_connection "$notion_connection" \
      --arg notion_data_source_id "$notion_data_source_id" \
      --arg notion_title_property "$notion_title_property" \
      --argjson channels "$channels_json" \
      '{
        channels: $channels,
        actor_id: $actor_id,
        tenant_id: $tenant_id,
        connections: {},
        bindings: {}
      }
      | if $github_connection == "" then . else
          .connections.github = $github_connection
          | .bindings.github = {repo: $github_repo}
        end
      | if $notion_connection == "" then . else
          .connections.notion = $notion_connection
          | .bindings.notion = {
              "parent.data_source_id": $notion_data_source_id,
              title_property: $notion_title_property
            }
        end'
  )"

  api_post "/rooms/$room_id/publications" "$payload"
}

main() {
  local command="${1:-help}"

  case "$command" in
    help|-h|--help)
      usage
      ;;

    doctor)
      shift || true
      cmd_doctor "$@"
      ;;

    wait-server)
      shift || true
      cmd_wait_server "$@"
      ;;

    wait-targets)
      shift || true
      cmd_wait_targets "$@"
      ;;

    targets)
      shift || true
      cmd_targets "$@"
      ;;

    room)
      shift || true
      cmd_room "$@"
      ;;

    create-room)
      shift || true
      cmd_create_room "$@"
      ;;

    run-room)
      shift || true
      cmd_run_room "$@"
      ;;

    publication-plan)
      shift || true
      cmd_publication_plan "$@"
      ;;

    publication-runs)
      shift || true
      cmd_publication_runs "$@"
      ;;

    live-demo)
      shift || true
      cmd_live_demo "$@"
      ;;

    start-install)
      shift || true
      cmd_start_install "$@"
      ;;

    show-install)
      shift || true
      cmd_show_install "$@"
      ;;

    complete-install)
      shift || true
      cmd_complete_install "$@"
      ;;

    connections)
      shift || true
      cmd_connections "$@"
      ;;

    publish)
      shift || true
      cmd_publish "$@"
      ;;

    *)
      die "unknown command: $command"
      ;;
  esac
}

main "$@"
