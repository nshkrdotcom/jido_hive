#!/usr/bin/env bash
set -euo pipefail

API_BASE="${JIDO_HIVE_API_BASE:-http://127.0.0.1:4000/api}"
ROOM_ID="${ROOM_ID:-room-$(date +%s)}"
TURN_TIMEOUT_MS="${JIDO_HIVE_TURN_TIMEOUT_MS:-180000}"

printf 'Waiting for local targets on %s\n' "$API_BASE"

TARGETS_READY=0

for _ in $(seq 1 150); do
  TARGETS_JSON="$(curl -fsS "$API_BASE/targets")"

  if grep -q '"target-architect"' <<<"$TARGETS_JSON" && grep -q '"target-skeptic"' <<<"$TARGETS_JSON"; then
    TARGETS_READY=1
    break
  fi

  sleep 0.2
done

if [[ "$TARGETS_READY" -ne 1 ]]; then
  printf 'Timed out waiting for target-architect and target-skeptic on %s\n' "$API_BASE" >&2
  exit 1
fi

printf 'Creating room %s\n' "$ROOM_ID"

curl -fsS -X POST "$API_BASE/rooms" \
  -H 'content-type: application/json' \
  -d @- <<JSON
{
  "room_id": "$ROOM_ID",
  "brief": "Develop a distributed collaboration protocol for two AI clients.",
  "rules": ["Every objection must target a claim."],
  "participants": [
    {
      "participant_id": "architect",
      "role": "architect",
      "target_id": "target-architect",
      "capability_id": "codex.exec.session"
    },
    {
      "participant_id": "skeptic",
      "role": "skeptic",
      "target_id": "target-skeptic",
      "capability_id": "codex.exec.session"
    }
  ]
}
JSON

printf '\nRunning refereed slice for %s\n' "$ROOM_ID"

curl -fsS -X POST "$API_BASE/rooms/$ROOM_ID/run" \
  -H 'content-type: application/json' \
  -d "{\"turn_timeout_ms\": $TURN_TIMEOUT_MS}"

printf '\nFinal room snapshot for %s\n' "$ROOM_ID"

curl -fsS "$API_BASE/rooms/$ROOM_ID"
printf '\n'

printf '\nDerived publication plan for %s\n' "$ROOM_ID"

curl -fsS "$API_BASE/rooms/$ROOM_ID/publication_plan"
printf '\n'
