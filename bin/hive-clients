#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
LOCAL_URL="ws://127.0.0.1:4000/socket/websocket"
PROD_URL="wss://jido-hive-server-test.app.nsai.online/socket/websocket"

mode="local"

usage() {
  cat <<'EOF'
Usage:
  bin/hive-clients [--local|--prod] [--count N]

Interactive client menu for:
- one generic worker
- two generic workers
- a custom 1..39 worker fan-out in one terminal
EOF
}

requested_count=''

while (($# > 0)); do
  case "$1" in
    --local)
      mode="local"
      shift
      ;;
    --prod)
      mode="prod"
      shift
      ;;
    --count)
      shift
      [[ $# -gt 0 ]] || {
        printf '--count requires a value\n' >&2
        exit 1
      }
      requested_count="$1"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      printf 'unknown option: %s\n' "$1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

case "$mode" in
  local)
    websocket_url="$LOCAL_URL"
    mode_flag=(--local)
    ;;
  prod)
    websocket_url="$PROD_URL"
    mode_flag=(--prod)
    ;;
esac

cleanup_children() {
  local pid=''

  for pid in "$@"; do
    if [[ -n "$pid" ]] && kill -0 "$pid" >/dev/null 2>&1; then
      kill "$pid" >/dev/null 2>&1 || true
      wait "$pid" >/dev/null 2>&1 || true
    fi
  done
}

run_action() {
  "$@" || true
}

worker_label() {
  local index="$1"
  printf 'worker-%02d' "$index"
}

validate_count() {
  local count="$1"

  [[ "$count" =~ ^[0-9]+$ ]] || {
    printf 'worker count must be an integer between 1 and 39\n' >&2
    return 1
  }

  if (( count < 1 || count > 39 )); then
    printf 'worker count must be between 1 and 39\n' >&2
    return 1
  fi
}

start_prefixed() {
  local label="$1"
  shift

  (
    "$@" 2>&1 | sed -u "s/^/[$label] /"
  ) &

  STARTED_PID="$!"
}

run_many() {
  local count="$1"
  local status=0
  local index='' label=''
  local -a worker_pids=()

  validate_count "$count" || return 1

  printf '[jido_hive clients] starting %s worker(s) in %s mode\n' "$count" "$mode"
  printf '[jido_hive clients] locked demo budget will default to %s turns when the room uses all connected workers\n' "$(( count * 3 ))"
  printf '[jido_hive clients] press Ctrl-C to stop all workers\n'
  printf '[jido_hive clients] watch here for system prompt preview, user prompt preview,\n'
  printf '[jido_hive clients] response preview, completed, and result published lines\n'

  for ((index = 1; index <= count; index += 1)); do
    label="$(worker_label "$index")"
    start_prefixed "$label" "$ROOT/bin/client-worker" "${mode_flag[@]}" --worker-index "$index"
    worker_pids+=("$STARTED_PID")
  done

  trap 'cleanup_children "${worker_pids[@]}"; exit 130' INT TERM

  if wait -n "${worker_pids[@]}"; then
    status=0
  else
    status=$?
  fi

  cleanup_children "${worker_pids[@]}"
  trap - INT TERM
  return "$status"
}

prompt_count() {
  local default_value="$1"
  local value=''

  read -r -p "worker count [$default_value]: " value
  printf '%s' "${value:-$default_value}"
}

print_menu() {
  cat <<EOF

jido_hive clients
mode:      $mode
websocket: $websocket_url

1. run one worker
2. run two workers in this terminal
3. run a custom worker count in this terminal
q. quit
EOF
}

if [[ -n "$requested_count" ]]; then
  run_action run_many "$requested_count"
  exit $?
fi

while true; do
  print_menu
  read -r -p 'choice: ' choice

  case "$choice" in
    1) run_action run_many 1 ;;
    2) run_action run_many 2 ;;
    3) run_action run_many "$(prompt_count 3)" ;;
    q|Q) exit 0 ;;
    *) printf 'unknown choice: %s\n' "$choice" >&2 ;;
  esac
done
