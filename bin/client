#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

LOCAL_URL="ws://127.0.0.1:4000/socket/websocket"
PROD_URL="wss://jido-hive-server-test.app.nsai.online/socket/websocket"
LOCAL_API_BASE="http://127.0.0.1:4000/api"
PROD_API_BASE="https://jido-hive-server-test.app.nsai.online/api"

usage() {
  cat <<'EOF'
Usage:
  bin/client [--local|--prod] [client options...]

Modes:
  --local  Connect to the local Phoenix server (default)
  --prod   Connect to https://jido-hive-server-test.app.nsai.online

Examples:
  bin/client
  bin/client --prod
  bin/client --url ws://127.0.0.1:4000/socket/websocket
EOF
}

mode="local"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --local)
      mode="local"
      shift
      ;;
    --prod)
      mode="prod"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    *)
      break
      ;;
  esac
done

case "$mode" in
  local) default_url="$LOCAL_URL" ;;
  prod) default_url="$PROD_URL" ;;
esac

case "$mode" in
  local) default_api_base="$LOCAL_API_BASE" ;;
  prod) default_api_base="$PROD_API_BASE" ;;
esac

URL="${JIDO_HIVE_URL:-$default_url}"
API_BASE_URL="${JIDO_HIVE_API_BASE:-$default_api_base}"
WORKSPACE_ID="${JIDO_HIVE_WORKSPACE_ID:-workspace-local}"
WORKSPACE_ROOT="${JIDO_HIVE_WORKSPACE_ROOT:-$ROOT}"
PARTICIPANT_ROLE="${PARTICIPANT_ROLE:-worker}"
PARTICIPANT_ID="${PARTICIPANT_ID:-worker-local}"
TARGET_ID="${TARGET_ID:-target-$PARTICIPANT_ID}"
USER_ID="${USER_ID:-user-$PARTICIPANT_ID}"
CAPABILITY_ID="${CAPABILITY_ID:-workspace.exec.session}"
JIDO_HIVE_PROVIDER="${JIDO_HIVE_PROVIDER:-codex}"
JIDO_HIVE_MODEL="${JIDO_HIVE_MODEL:-gpt-5.4}"
JIDO_HIVE_REASONING_EFFORT="${JIDO_HIVE_REASONING_EFFORT:-low}"
JIDO_HIVE_TIMEOUT_MS="${JIDO_HIVE_TIMEOUT_MS:-}"
JIDO_HIVE_CLI_PATH="${JIDO_HIVE_CLI_PATH:-}"

cd "$ROOT/jido_hive_worker_runtime"

exec mix run --no-halt -e 'JidoHiveWorkerRuntime.CLI.main(System.argv())' -- \
  --url "$URL" \
  --api-base-url "$API_BASE_URL" \
  --workspace-id "$WORKSPACE_ID" \
  --user-id "$USER_ID" \
  --participant-id "$PARTICIPANT_ID" \
  --participant-role "$PARTICIPANT_ROLE" \
  --target-id "$TARGET_ID" \
  --capability-id "$CAPABILITY_ID" \
  --workspace-root "$WORKSPACE_ROOT" \
  --provider "$JIDO_HIVE_PROVIDER" \
  --model "$JIDO_HIVE_MODEL" \
  --reasoning-effort "$JIDO_HIVE_REASONING_EFFORT" \
  ${JIDO_HIVE_ROOM_ID:+--room-id "$JIDO_HIVE_ROOM_ID"} \
  ${JIDO_HIVE_TIMEOUT_MS:+--timeout-ms "$JIDO_HIVE_TIMEOUT_MS"} \
  ${JIDO_HIVE_CLI_PATH:+--cli-path "$JIDO_HIVE_CLI_PATH"} \
  "$@"
